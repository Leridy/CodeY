{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "CodeY Design Tokens -- AI IDE 统一设计语言定义",

  "colors": {
    "$description": "色彩系统 -- 基于 Deep Navy + Rose Accent 的 AI IDE 配色方案",

    "primary": {
      "$description": "主色调 -- Deep Navy 系列，传达专业、专注的技术氛围",
      "50":  "#e8eaf6",
      "100": "#c5cae9",
      "200": "#9fa8da",
      "300": "#7986cb",
      "400": "#5c6bc0",
      "500": "#0f3460",
      "600": "#0d2d54",
      "700": "#0a2547",
      "800": "#081e3b",
      "900": "#05162e"
    },

    "accent": {
      "$description": "强调色 -- Rose 系列，用于交互高亮、CTA 和状态指示",
      "50":  "#fce4ec",
      "100": "#f8bbd0",
      "200": "#f48fb1",
      "300": "#f06292",
      "400": "#ec407a",
      "500": "#e94560",
      "600": "#d81b4a",
      "700": "#c2185b",
      "800": "#ad1457",
      "900": "#880e4f"
    },

    "neutral": {
      "$description": "中性色 -- 用于文本、背景、边框的基础灰阶",
      "50":  "#fafafa",
      "100": "#f5f5f5",
      "200": "#eeeeee",
      "300": "#e0e0e0",
      "400": "#bdbdbd",
      "500": "#9e9e9e",
      "600": "#757575",
      "700": "#616161",
      "800": "#424242",
      "900": "#212121"
    },

    "success": {
      "$description": "成功状态 -- 绿色系，用于完成状态、成功操作",
      "50":  "#e8f5e9",
      "100": "#c8e6c9",
      "200": "#a5d6a7",
      "300": "#81c784",
      "400": "#66bb6a",
      "500": "#4caf50",
      "600": "#43a047",
      "700": "#388e3c",
      "800": "#2e7d32",
      "900": "#1b5e20"
    },

    "warning": {
      "$description": "警告状态 -- 橙色系，用于待审批、需要注意的操作",
      "50":  "#fff3e0",
      "100": "#ffe0b2",
      "200": "#ffcc80",
      "300": "#ffb74d",
      "400": "#ffa726",
      "500": "#ff9800",
      "600": "#fb8c00",
      "700": "#f57c00",
      "800": "#ef6c00",
      "900": "#e65100"
    },

    "error": {
      "$description": "错误状态 -- 红色系，用于失败、错误指示",
      "50":  "#ffebee",
      "100": "#ffcdd2",
      "200": "#ef9a9a",
      "300": "#e57373",
      "400": "#ef5350",
      "500": "#f44336",
      "600": "#e53935",
      "700": "#d32f2f",
      "800": "#c62828",
      "900": "#b71c1c"
    },

    "info": {
      "$description": "信息状态 -- 蓝色系，用于运行中、提示信息",
      "50":  "#e3f2fd",
      "100": "#bbdefb",
      "200": "#90caf9",
      "300": "#64b5f6",
      "400": "#42a5f5",
      "500": "#2196f3",
      "600": "#1e88e5",
      "700": "#1976d2",
      "800": "#1565c0",
      "900": "#0d47a1"
    },

    "tool": {
      "$description": "Tool 类型专用色 -- 每种 Tool 类型有独立色彩标识",
      "bash":   { "dark": "#4caf50", "light": "#388e3c" },
      "edit":   { "dark": "#2196f3", "light": "#1976d2" },
      "git":    { "dark": "#ff9800", "light": "#f57c00" },
      "file":   { "dark": "#9c27b0", "light": "#7b1fa2" },
      "search": { "dark": "#00bcd4", "light": "#0097a7" }
    },

    "theme": {
      "dark": {
        "bg":            "#1a1a2e",
        "surface":       "#16213e",
        "primary":       "#0f3460",
        "accent":        "#e94560",
        "text-primary":  "#e0e0e0",
        "text-secondary":"#9e9e9e",
        "text-disabled": "#616161",
        "text-inverse":  "#1a1a2e",
        "border":        "#2a2a4a",
        "border-hover":  "#3a3a5a",
        "border-focus":  "#e94560"
      },
      "light": {
        "bg":            "#f5f5f5",
        "surface":       "#ffffff",
        "primary":       "#1976d2",
        "accent":        "#e91e63",
        "text-primary":  "#212121",
        "text-secondary":"#757575",
        "text-disabled": "#bdbdbd",
        "text-inverse":  "#ffffff",
        "border":        "#e0e0e0",
        "border-hover":  "#bdbdbd",
        "border-focus":  "#e91e63"
      }
    }
  },

  "typography": {
    "$description": "排版系统 -- Inter 正文 + JetBrains Mono 代码的双字体方案",

    "fontFamily": {
      "sans": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'SF Mono', Consolas, monospace"
    },

    "fontSize": {
      "$description": "字号阶梯 -- 基于 1.125 比例尺，16px 为基准",
      "2xs":  "0.625rem",
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem"
    },

    "fontWeight": {
      "normal":   400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },

    "lineHeight": {
      "tight":   1.25,
      "snug":    1.375,
      "normal":  1.5,
      "relaxed": 1.625
    },

    "letterSpacing": {
      "tighter": "-0.05em",
      "tight":   "-0.025em",
      "normal":  "0em",
      "wide":    "0.025em",
      "wider":   "0.05em"
    }
  },

  "spacing": {
    "$description": "间距系统 -- 基于 4px 网格，所有间距为 4 的整数倍",
    "0":    "0",
    "px":   "1px",
    "0.5":  "0.125rem",
    "1":    "0.25rem",
    "1.5":  "0.375rem",
    "2":    "0.5rem",
    "2.5":  "0.625rem",
    "3":    "0.75rem",
    "3.5":  "0.875rem",
    "4":    "1rem",
    "5":    "1.25rem",
    "6":    "1.5rem",
    "7":    "1.75rem",
    "8":    "2rem",
    "9":    "2.25rem",
    "10":   "2.5rem",
    "12":   "3rem",
    "14":   "3.5rem",
    "16":   "4rem",
    "20":   "5rem",
    "24":   "6rem",
    "32":   "8rem"
  },

  "borderRadius": {
    "$description": "圆角系统 -- 从尖锐到圆润的递进",
    "none": "0",
    "sm":   "0.125rem",
    "md":   "0.375rem",
    "lg":   "0.5rem",
    "xl":   "0.75rem",
    "2xl":  "1rem",
    "3xl":  "1.5rem",
    "full": "9999px"
  },

  "boxShadow": {
    "$description": "阴影系统 -- 三级阴影深度，用于卡片、弹窗、浮层",
    "sm":    "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md":    "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
    "lg":    "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
    "xl":    "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
    "inner": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)",
    "glow": {
      "$description": "发光阴影 -- 用于 focus 状态和高亮指示",
      "accent":  "0 0 0 3px rgba(233, 69, 96, 0.3)",
      "primary": "0 0 0 3px rgba(15, 52, 96, 0.3)"
    }
  },

  "animation": {
    "$description": "动画系统 -- 统一的过渡和动画参数",

    "duration": {
      "instant": "0ms",
      "fast":    "100ms",
      "normal":  "200ms",
      "slow":    "300ms",
      "slower":  "500ms"
    },

    "easing": {
      "ease-in":     "cubic-bezier(0.4, 0, 1, 1)",
      "ease-out":    "cubic-bezier(0, 0, 0.2, 1)",
      "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring":      "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },

    "transition": {
      "colors":    "color 200ms ease-in-out, background-color 200ms ease-in-out, border-color 200ms ease-in-out",
      "opacity":   "opacity 200ms ease-in-out",
      "shadow":    "box-shadow 200ms ease-in-out",
      "transform": "transform 200ms ease-in-out",
      "all":       "all 200ms ease-in-out"
    }
  },

  "breakpoint": {
    "$description": "响应式断点 -- 对应 useLayoutMode 的三种模式",
    "mobile":  "0px",
    "tablet":  "768px",
    "desktop": "1280px"
  },

  "zIndex": {
    "$description": "层级系统 -- 控制元素的堆叠顺序",
    "base":     0,
    "dropdown": 10,
    "sticky":   20,
    "panel":    30,
    "overlay":  40,
    "modal":    50,
    "popover":  60,
    "toast":    70,
    "tooltip":  80
  }
}
