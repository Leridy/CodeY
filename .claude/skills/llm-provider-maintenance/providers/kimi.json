{
  "id": "kimi",
  "name": "Kimi",
  "base_url": "https://api.moonshot.cn/v1",
  "api_key_env": "MOONSHOT_API_KEY",
  "chat_endpoint": "/chat/completions",
  "default_model": "moonshot-v1-8k",
  "supports_streaming": true,
  "supports_function_calling": false,
  "headers": {
    "Authorization": "Bearer ${api_key}"
  },
  "models": [
    {"id": "moonshot-v1-8k", "name": "Moonshot V1 8K", "context_window": 8192, "max_output_tokens": 4096},
    {"id": "moonshot-v1-32k", "name": "Moonshot V1 32K", "context_window": 32768, "max_output_tokens": 8192},
    {"id": "moonshot-v1-128k", "name": "Moonshot V1 128K", "context_window": 131072, "max_output_tokens": 8192}
  ]
}
