{
  "id": "minimax",
  "name": "MiniMax",
  "base_url": "https://api.minimax.chat/v1",
  "api_key_env": "MINIMAX_API_KEY",
  "chat_endpoint": "/chat/completions",
  "default_model": "abab6.5s-chat",
  "supports_streaming": true,
  "supports_function_calling": false,
  "headers": {
    "Authorization": "Bearer ${api_key}"
  },
  "models": [
    {"id": "abab6.5s-chat", "name": "Abab 6.5s", "context_window": 24576, "max_output_tokens": 4096},
    {"id": "abab6.5-chat", "name": "Abab 6.5", "context_window": 24576, "max_output_tokens": 4096},
    {"id": "abab5.5-chat", "name": "Abab 5.5", "context_window": 16384, "max_output_tokens": 4096}
  ]
}
