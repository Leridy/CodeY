    {"id": "hunyuan-standard", "name": "混元 Standard", "context_window": 32768, "max_output_tokens": 4096},
    {"id": "hunyuan-lite", "name": "混元 Lite", "context_window": 32768, "max_output_tokens": 4096}
  ]
}
